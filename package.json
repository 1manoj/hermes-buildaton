{
  "name": "overnight-newsroom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --env-file-if-exists=.env.local src/server.js",
    "start": "node --env-file-if-exists=.env --env-file-if-exists=.env.local src/server.js",
    "test": "node --test",
    "demo": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/demo.js",
    "telegram:discover": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/telegram-discover.js",
    "integrations:check": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/check-integrations.js",
    "bot": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/bot.js",
    "digest:send": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/send-personalized.js",
    "watch:run": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/watch-intelligence.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "convex": "^1.42.1"
  }
